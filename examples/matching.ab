module Matching

// Matching — pattern matching reference
// Demonstrates sum types with record variants and comprehensive match syntax.

enum Shape =
  Circle { radius: real }
  | Rectangle { width: real, height: real }
  | Triangle { base: real, height: real }
  | Point

enum Expr =
  Lit { value: int }
  | Add { left: Expr, right: Expr }
  | Neg { inner: Expr }

enum OrderStatus = Pending | Confirmed | Shipped | Delivered | Cancelled

// Simple constructor matching
fn status_label(s: OrderStatus): string =
  match s {
    Pending => "waiting"
    Confirmed => "confirmed"
    Shipped => "in transit"
    Delivered => "complete"
    Cancelled => "cancelled"
  }

// Record destructuring
fn area(s: Shape): real =
  match s {
    Circle { radius: r } => 3.14159 * r * r
    Rectangle { width: w, height: h } => w * h
    Triangle { base: b, height: h } => 0.5 * b * h
    Point => 0
  }

// Guards
fn describe(s: Shape): string =
  match s {
    Circle { radius: r } if r > 100 => "large circle"
    Circle { .. } => "circle"
    Rectangle { width: w, height: h } if w == h => "square"
    Rectangle { .. } => "rectangle"
    _ => "other"
  }

// Or-patterns
fn is_terminal(s: OrderStatus): bool =
  match s {
    Delivered | Cancelled => true
    _ => false
  }

// Nested patterns
fn is_double_negation(e: Expr): bool =
  match e {
    Neg { inner: Neg { inner: _ } } => true
    _ => false
  }
