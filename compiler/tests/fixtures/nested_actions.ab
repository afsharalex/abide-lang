module NestedActions

// Phase 7: Nested actions in Choose/ForAll

enum TaskStatus = Open | InProgress | Done
enum LogKind = Started | Completed

entity Task {
  status: TaskStatus = @Open
  action start() requires status == @Open { status' = @InProgress }
  action complete() requires status == @InProgress { status' = @Done }
}

entity AuditLog {
  kind: LogKind = @Started
  action set_completed() requires kind == @Started { kind' = @Completed }
}

// ── Test 1: Create inside Choose ────────────────────────────────────

system CreateInChoose {
  use Task
  use AuditLog

  event start_with_log() {
    choose t: Task where t.status == @Open {
      t.start()
      create AuditLog {}
    }
  }
}

// After start_with_log fires, if a task became InProgress then
// an AuditLog must exist. Should be CHECKED.
verify create_in_choose for CreateInChoose[0..3] {
  assert always (
    all t: Task | t.status == @InProgress implies
      exists l: AuditLog | l.kind == @Started
  )
}

// ── Test 2: Create inside ForAll ────────────────────────────────────

system CreateInForAll {
  use Task
  use AuditLog

  // For each active task, start it and create an audit log
  event start_all_with_logs() {
    for t: Task {
      t.start()
      create AuditLog {}
    }
  }
}

// After starting tasks, if any task is InProgress then an AuditLog
// should exist. Should be CHECKED.
verify create_in_forall for CreateInForAll[0..3] {
  assert always (
    all t: Task | t.status == @InProgress implies
      exists l: AuditLog | l.kind == @Started
  )
}

// ── Test 3: CrossCall INSIDE Choose ─────────────────────────────────

system Logger {
  use AuditLog

  event log_complete() {
    choose l: AuditLog where l.kind == @Started {
      l.set_completed()
    }
  }
}

system CrossCallInChoose {
  use Task

  // CrossCall is nested inside the Choose block
  event complete_and_log() {
    choose t: Task where t.status == @InProgress {
      t.complete()
      Logger::log_complete()
    }
  }
}

// After completing a task, it should be Done. Should be CHECKED.
verify crosscall_in_choose for CrossCallInChoose[0..3] {
  assert always (
    all t: Task | t.status == @Done implies t.status == @Done
  )
}

// ── Test 4: ForAll INSIDE Choose ────────────────────────────────────

entity Worker {
  status: TaskStatus = @Open
  action activate() requires status == @Open { status' = @InProgress }
  action deactivate() requires status == @InProgress { status' = @Open }
  // start() exists on Worker (goes to Done) — used to verify that nested
  // Choose framing prevents the solver from applying the wrong action
  action start() requires status == @Open { status' = @Done }
}

system ForAllInChoose {
  use Task
  use Worker

  // ForAll is nested inside the Choose block
  event start_and_deactivate() {
    choose t: Task where t.status == @Open {
      t.start()
      for w: Worker {
        w.deactivate()
      }
    }
  }
}

// After the event, if a task is InProgress then no worker should
// remain InProgress (they were all deactivated). Should be CHECKED.
verify forall_in_choose for ForAllInChoose[0..3] {
  assert always (
    all t: Task | t.status == @InProgress implies
      no w: Worker | w.status == @InProgress
  )
}

// ── Test 5: Cross-entity Apply target ───────────────────────────────
// Ensures that Apply targets are resolved correctly when the target
// is not the inner bound variable (e.g., t.start() inside choose w:).

system CrossEntityApply {
  use Task
  use Worker

  event make_task() { create Task {} }
  event make_worker() { create Worker {} }

  // t.start() targets the outer Choose variable, NOT the inner Worker.
  // The inner Worker slot has NO Apply — it must be framed (unchanged).
  // Worker.start() exists and goes to @Done, so without framing, the
  // solver could mutate the Worker to @Done.
  event start_task_via_inner_choose() {
    choose t: Task where t.status == @Open {
      choose w: Worker where w.status == @Open {
        t.start()
      }
    }
  }
}

// Worker should never reach Done. Even though Worker.start() exists
// (Open -> Done), only t.start() fires in the event body. The inner
// Worker slot must be framed to prevent the solver from mutating it.
verify cross_entity_target for CrossEntityApply[0..5] {
  assert always (all w: Worker | w.status != @Done)
}
