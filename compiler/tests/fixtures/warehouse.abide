// Warehouse module — used by logistics.abide for multi-module alias testing

module Warehouse

pub enum SlotStatus = Empty | Reserved | Full

pub entity Slot {
  id: Id
  status: SlotStatus = @Empty
  capacity: Int

  action reserve()
    requires status == @Empty {
    status' = @Reserved
  }

  action fill()
    requires status == @Reserved {
    status' = @Full
  }

  action clear()
    requires status == @Full {
    status' = @Empty
  }
}

system Warehouse {
  use Slot

  event add_slot(cap: Int) {
    create Slot {
      id = cap
      status = @Empty
      capacity = cap
    }
  }

  next {
    else => idle
  }
}
