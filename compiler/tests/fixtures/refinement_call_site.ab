module RefinementCallSite

// Function with single refinement type param
fn safe_div(a: Int, b: Int { $ != 0 }): Int
{
  a / b
}

// Function with multiple refinement params
fn add_positive(x: Int { $ > 0 }, y: Int { $ > 0 }): Int
  ensures result > 1
{
  x + y
}

// Good: literal satisfying refinement
fn call_literal(): Int
  ensures result == 5
{
  safe_div(10, 2)
}

// Good: variable with requires satisfying refinement (b > 0 implies b != 0)
fn call_variable(a: Int, b: Int): Int
  requires b > 0
  ensures result >= 0 or result < 0
{
  safe_div(a, b)
}

// Good: both refinements satisfied by caller requires
fn call_both(a: Int, b: Int): Int
  requires a > 0
  requires b > 0
  ensures result > 1
{
  add_positive(a, b)
}

// BAD: no guarantee b != 0 (refinement desugared to requires b != 0)
fn call_bad(a: Int, b: Int): Int
  ensures result >= 0 or result < 0
{
  safe_div(a, b)
}

// BAD: only first refinement satisfied (b not > 0)
fn call_one_bad(a: Int, b: Int): Int
  requires a > 0
  ensures result > 1
{
  add_positive(a, b)
}

// ── Alias-based refinement types ────────────────────────────────────

type Positive = Int { $ > 0 }
type NonNeg = Int { $ >= 0 }

fn double_pos(x: Positive): Int
  ensures result > 0
{
  x + x
}

fn succ(n: NonNeg): Int
  ensures result > n
{
  n + 1
}

// Good: literal satisfying alias refinement
fn call_alias_literal(): Int
  ensures result > 0
{
  double_pos(5)
}

// Good: requires satisfying alias refinement
fn call_alias_good(x: Int): Int
  requires x > 0
  ensures result > 0
{
  double_pos(x)
}

// Good: Positive (> 0) implies NonNeg (>= 0) — subtype relation
fn call_alias_subtype(x: Positive): Int
  ensures result > x
{
  succ(x)
}

// BAD: no guarantee x > 0 for Positive alias
fn call_alias_bad(x: Int): Int
  ensures result > 0
{
  double_pos(x)
}

// BAD: NonNeg (>= 0) does not imply Positive (> 0)
fn call_alias_wrong(x: NonNeg): Int
  ensures result > 0
{
  double_pos(x)
}
