module Lambdas

// Lambda expression tests (Phase 6 of verification-gaps.md)

// --- Immediate application ---

fn apply_single(): Int
  ensures result == 2
{
  (fn(y: Int): Int => y + 1)(1)
}

fn apply_multi(): Int
  ensures result == 7
{
  (fn(x: Int, y: Int): Int => x + y)(3, 4)
}

fn apply_three_args(): Int
  ensures result == 12
{
  (fn(a: Int, b: Int, c: Int): Int => a * b + c)(2, 5, 2)
}

// --- Lambda identity ---

fn identity(x: Int): Int
  ensures result == x
{
  (fn(y: Int): Int => y)(x)
}

// --- Let-bound lambda ---

fn let_lambda(): Int
  ensures result == 10
{
  let f = fn(x: Int): Int => x * 2
  in f(5)
}

// --- Closure over parameter ---

fn closure(x: Int): Int
  ensures result == x + 1
{
  let inc = fn(y: Int): Int => y + 1
  in inc(x)
}

// --- Lambda with Bool return ---

fn bool_lambda(): Bool
  ensures result == true
{
  (fn(x: Int): Bool => x > 0)(42)
}

// --- Lambda in ensures ---

fn ensures_lambda(): Int
  ensures (fn(x: Int): Int => x + 1)(0) == 1
{
  0
}

// --- Lambda in assert ---

fn assert_lambda(): Int
  ensures result == 0
{
  assert (fn(x: Int): Int => x + 1)(0) == 1
  0
}

// --- Partial application (currying) ---

fn partial_app(): Int
  ensures result == 3
{
  let add = fn(x: Int, y: Int): Int => x + y
  in let inc = add(1)
     in inc(2)
}

// --- Multi-step partial application ---

fn multi_partial(): Int
  ensures result == 6
{
  let f = fn(a: Int, b: Int, c: Int): Int => a + b + c
  in let g = f(1)
     in let h = g(2)
        in h(3)
}
