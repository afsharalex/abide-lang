// Billing module — cross-module dependency for commerce.abide

module Billing

pub enum PaymentStatus = Opened | Captured | Failed

pub entity PaymentIntent {
  order_id: Id
  amount: Int
  status: PaymentStatus = @Opened

  action capture()
    requires status == @Opened
    requires amount > 0 {
    status' = @Captured
  }

  action fail()
    requires status == @Opened {
    status' = @Failed
  }
}

system Billing {
  use PaymentIntent

  event open_intent(order_id: Id, amount: Int) {
    create PaymentIntent {
      order_id = order_id
      amount = amount
      status = @Opened
    }
  }

  event capture_payment(order_id: Id)
    requires exists p: PaymentIntent | p.order_id == order_id and p.status == @Opened
    ensures exists p: PaymentIntent | p.order_id == order_id and p.status == @Captured {
    choose p: PaymentIntent where p.order_id == order_id {
      p.capture()
    }
    Commerce::confirm_payment(order_id: order_id)
  }

  next {
    else => idle
  }
}
