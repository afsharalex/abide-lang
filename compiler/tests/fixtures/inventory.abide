module Inventory

// Inventory management example
// Demonstrates: multiple entity types interacting, quantity tracking,
// cross-system coordination, exclusive choice, concurrent operations

type ProductStatus = Available | Discontinued | OutOfStock
type ReservationStatus = Held | Confirmed | Released | Expired
type FulfillmentStatus = Pending | Picking | Packed | Shipped | Delivered

entity Product {
  id: Id
  name: String
  quantity: Int
  status: ProductStatus = @Available

  action restock(amount: Int)
    requires status != @Discontinued
    requires amount > 0 {
    quantity' = quantity + amount
    status' = @Available
  }

  action reserve(amount: Int)
    requires status == @Available
    requires quantity >= amount
    requires amount > 0 {
    quantity' = quantity - amount
  }

  action release(amount: Int)
    requires amount > 0 {
    quantity' = quantity + amount
  }

  action discontinue()
    requires status == @Available {
    status' = @Discontinued
  }

  action mark_out_of_stock()
    requires quantity == 0
    requires status == @Available {
    status' = @OutOfStock
  }
}

entity Reservation {
  id: Id
  product_id: Id
  quantity: Int
  status: ReservationStatus = @Held

  action confirm()
    requires status == @Held {
    status' = @Confirmed
  }

  action release()
    requires status == @Held {
    status' = @Released
  }

  action expire()
    requires status == @Held {
    status' = @Expired
  }
}

entity Fulfillment {
  id: Id
  reservation_id: Id
  status: FulfillmentStatus = @Pending

  action start_picking()
    requires status == @Pending {
    status' = @Picking
  }

  action pack()
    requires status == @Picking {
    status' = @Packed
  }

  action ship()
    requires status == @Packed {
    status' = @Shipped
  }

  action deliver()
    requires status == @Shipped {
    status' = @Delivered
  }
}

system Warehouse {
  use Product
  use Reservation

  event reserve_product(product_id: Id, qty: Int)
    requires exists p: Product |
      p.id == product_id and
      p.status == @Available and
      p.quantity >= qty
    requires qty > 0 {
    choose p: Product where p.id == product_id {
      p.reserve(qty)
    }
    create Reservation {
      product_id = product_id
      quantity = qty
      status = @Held
    }
  }

  event release_reservation(reservation_id: Id)
    requires exists r: Reservation |
      r.id == reservation_id and r.status == @Held {
    choose r: Reservation where r.id == reservation_id {
      r.release()
    }
    // Return quantity to product
    choose p: Product where p.id == r.product_id {
      p.release(r.quantity)
    }
  }

  event confirm_reservation(reservation_id: Id)
    requires exists r: Reservation |
      r.id == reservation_id and r.status == @Held
    ensures exists r: Reservation |
      r.id == reservation_id and r.status == @Confirmed {
    choose r: Reservation where r.id == reservation_id {
      r.confirm()
    }
    Shipping::begin_fulfillment(reservation_id: reservation_id)
  }

  event restock_product(product_id: Id, amount: Int)
    requires exists p: Product | p.id == product_id
    requires amount > 0 {
    choose p: Product where p.id == product_id {
      p.restock(amount)
    }
  }

  next {
    when exists p: Product | p.quantity == 0 and p.status == @Available =>
      Warehouse::restock_product
    else => idle
  }
}

system Shipping {
  use Fulfillment

  event begin_fulfillment(reservation_id: Id) {
    create Fulfillment {
      reservation_id = reservation_id
      status = @Pending
    }
  }

  event pick(fulfillment_id: Id)
    requires exists f: Fulfillment |
      f.id == fulfillment_id and f.status == @Pending {
    choose f: Fulfillment where f.id == fulfillment_id {
      f.start_picking()
    }
  }

  event pack_and_ship(fulfillment_id: Id)
    requires exists f: Fulfillment |
      f.id == fulfillment_id and f.status == @Picking {
    choose f: Fulfillment where f.id == fulfillment_id {
      f.pack()
      f.ship()
    }
  }

  event mark_delivered(fulfillment_id: Id)
    requires exists f: Fulfillment |
      f.id == fulfillment_id and f.status == @Shipped {
    choose f: Fulfillment where f.id == fulfillment_id {
      f.deliver()
    }
  }

  next {
    when exists f: Fulfillment | f.status == @Pending => Shipping::pick
    when exists f: Fulfillment | f.status == @Picking => Shipping::pack_and_ship
    else => idle
  }
}

// Predicates
pred quantity_non_negative(p: Product) = p.quantity >= 0
pred reservation_consistent(r: Reservation) =
  r.status == @Released implies r.quantity >= 0

// Properties
prop inventory_safe for Warehouse =
  always all p: Product | quantity_non_negative(p)

prop fulfillment_progress for Shipping =
  always all f: Fulfillment |
    f.status == @Pending implies eventually f.status == @Shipped

// Bounded checks
verify inventory_safety for Warehouse[0..8] {
  assert inventory_safe
}

verify end_to_end for Warehouse[0..8], Shipping[0..8] {
  assert always all p: Product | p.quantity >= 0
  assert always all f: Fulfillment |
    f.status == @Delivered implies always f.status == @Delivered
}

// Scenarios
scene reserve_and_confirm for Warehouse {
  given {
    let p = one Product where p.quantity == 50 and p.status == @Available
  }
  when {
    action res = Warehouse::reserve_product(p.id, 10){one}
    action conf = Warehouse::confirm_reservation(res.id){one}
    assume res -> conf
  }
  then {
    assert p.quantity == 40
  }
}

scene reservation_release_restores_quantity for Warehouse {
  given {
    let p = one Product where p.quantity == 100
  }
  when {
    action res = Warehouse::reserve_product(p.id, 25){one}
    action rel = Warehouse::release_reservation(res.id){one}
    assume res -> rel
  }
  then {
    assert p.quantity == 100
  }
}
