module Fairness

// Liveness and fairness tests (Phase 4 of model-verification-gaps.md)

enum Light = Red | Green

entity Signal {
  color: Light = @Red
  action go_green() requires color == @Red { color' = @Green }
  action go_red() requires color == @Green { color' = @Red }
}

system FairTraffic {
  use Signal
  fair event create_signal() { create Signal {} }
  fair event toggle() {
    choose s: Signal where s.color == @Red { s.go_green() }
  }
  fair event reset() {
    choose s: Signal where s.color == @Green { s.go_red() }
  }
}

system UnfairTraffic {
  use Signal
  event create_signal() { create Signal {} }
  // toggle NOT fair — can be ignored indefinitely
  event toggle() {
    choose s: Signal where s.color == @Red { s.go_green() }
  }
  // reset IS fair — fires when enabled (but doesn't help Red→Green)
  fair event reset() {
    choose s: Signal where s.color == @Green { s.go_red() }
  }
}

// Fair events + small scope: liveness should be CHECKED
verify fair_signal for FairTraffic[0..3] {
  assert all s: Signal |
    s.color == @Red implies eventually s.color == @Green
}

// Unfair toggle: liveness should find LIVENESS_VIOLATION
// (toggle can be starved, signal stays Red forever)
verify unfair_signal for UnfairTraffic[0..8] {
  assert all s: Signal |
    s.color == @Red implies eventually s.color == @Green
}

// Safety property (no eventually): should still be PROVED/CHECKED normally
verify safety_check for FairTraffic[0..5] {
  assert always all s: Signal |
    s.color == @Red or s.color == @Green
}
