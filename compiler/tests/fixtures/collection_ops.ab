module CollectionOps

// Phase 1: Collection operations — comprehensive tests

// ── Set<Int> operations via qualified functions ─────────────────────

lemma set_union_int {
  Set::union(Set(1, 2), Set(2, 3)) == Set(1, 2, 3)
}

lemma set_intersect_int {
  Set::intersect(Set(1, 2, 3), Set(2, 3, 4)) == Set(2, 3)
}

lemma set_diff_int {
  Set::diff(Set(1, 2, 3), Set(2)) == Set(1, 3)
}

lemma set_subset_int {
  Set::subset(Set(1, 2), Set(1, 2, 3))
}

lemma set_disjoint_int {
  Set::disjoint(Set(1, 2), Set(3, 4))
}

lemma set_not_disjoint_int {
  not Set::disjoint(Set(1, 2), Set(2, 3))
}

lemma set_member_int {
  Set::member(1, Set(1, 2, 3))
}

lemma set_not_member_int {
  not Set::member(5, Set(1, 2, 3))
}

// ── Set::member on Real (polymorphic) ───────────────────────────────

lemma set_member_real {
  Set::member(1.5, Set(1.5, 2.5))
}

// ── Set operations via operators ────────────────────────────────────

lemma set_union_op {
  Set(1, 2) <> Set(2, 3) == Set(1, 2, 3)
}

lemma set_disjoint_op {
  Set(1, 2) !* Set(3, 4)
}

lemma set_not_disjoint_op {
  not (Set(1, 2) !* Set(2, 3))
}

// ── Type-directed operator overloading (*, -, <=) ───────────────────
// These dispatch to Set ops at IR lowering time based on Set<T> type,
// NOT at SMT level — so Map<K,Bool> and Seq<Bool> are not affected.

lemma set_intersect_star {
  Set(1, 2, 3) * Set(2, 3, 4) == Set(2, 3)
}

lemma set_diff_minus {
  Set(1, 2, 3) - Set(2) == Set(1, 3)
}

lemma set_subset_le {
  Set(1, 2) <= Set(1, 2, 3)
}

// ── Seq operations ──────────────────────────────────────────────────

lemma seq_head_int {
  Seq::head(Seq(10, 20, 30)) == 10
}

// Seq<Bool> should not crash (was a bug: SeqLit always used Int default)
lemma seq_bool_eq {
  Seq(true, false) == Seq(true, false)
}
