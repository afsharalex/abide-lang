module ConstructorFields

// Constructor field destructuring tests (Phase 5 of verification-gaps.md)

enum Shape = Circle { radius: Int } | Rect { w: Int, h: Int }

// --- Single-field destructuring ---

fn get_radius_or_zero(s: Shape): Int
  ensures match s {
    Circle { radius: r } => result == r
    _ => result == 0
  }
{
  match s {
    Circle { radius: r } => r
    Rect { w: w, h: h } => 0
  }
}

// --- Multi-field destructuring ---

fn rect_perimeter(s: Shape): Int
  ensures match s {
    Rect { w: w, h: h } => result == 2 * (w + h)
    _ => result == 0
  }
{
  match s {
    Circle { radius: r } => 0
    Rect { w: w, h: h } => 2 * (w + h)
  }
}

// --- Constant return across all branches ---

fn always_42(s: Shape): Int
  ensures result == 42
{
  match s {
    Circle { radius: r } => 42
    Rect { w: w, h: h } => 42
  }
}

// --- Mixed fieldless and field-bearing constructors ---

enum Option = None | Some { value: Int }

fn get_or_default(o: Option, d: Int): Int
  ensures match o {
    Some { value: v } => result == v
    None => result == d
  }
{
  match o {
    Some { value: v } => v
    None => d
  }
}

// --- Constructor expressions with fields ---

fn make_some(x: Int): Option
  ensures match result {
    Some { value: v } => v == x
    None => false
  }
{
  @Some { value: x }
}

fn make_none(): Option
  ensures match result {
    None => true
    Some { value: v } => false
  }
{
  @None
}

// --- Reordered fields (by name, not position) ---

fn reordered_ctor_fields(x: Int): Int
  ensures result == 120
{
  match @Rect { h: 20, w: 1 } {
    Rect { w: w, h: h } => 100 * w + h
    _ => 0
  }
}

fn reordered_pat_fields(x: Int): Int
  ensures result == 120
{
  match @Rect { w: 1, h: 20 } {
    Rect { h: h, w: w } => 100 * w + h
    _ => 0
  }
}
