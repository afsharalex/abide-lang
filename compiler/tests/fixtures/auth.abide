// Authentication & authorization example
// Demonstrates: shared entity reuse, multiple systems operating
// on the same entity, cross-system calls, temporal properties

type UserStatus = Active | Suspended | Locked | Deleted
type Role = Admin | Member | Guest
type SessionStatus = Valid | Expired | Revoked

entity User {
  field id: Id
  field email: String
  field status: UserStatus = @Active
  field role: Role = @Member
  field failed_attempts: Int

  action activate()
    requires status == @Suspended {
    status' = @Active
    failed_attempts' = 0
  }

  action suspend()
    requires status == @Active {
    status' = @Suspended
  }

  action lock()
    requires status == @Active
    requires failed_attempts >= 5 {
    status' = @Locked
  }

  action delete()
    requires status == @Suspended {
    status' = @Deleted
  }

  action record_failure()
    requires status == @Active {
    failed_attempts' = failed_attempts + 1
  }

  action reset_failures()
    requires status == @Active {
    failed_attempts' = 0
  }
}

entity Session {
  field id: Id
  field user_id: Id
  field status: SessionStatus = @Valid

  action expire()
    requires status == @Valid {
    status' = @Expired
  }

  action revoke()
    requires status == @Valid {
    status' = @Revoked
  }
}

system Auth {
  uses User
  uses Session

  event login(user_id: Id)
    requires exists u: User | u.id == user_id and u.status == @Active {
    choose u: User where u.id == user_id {
      u.reset_failures()
    }
    create Session {
      user_id = user_id
      status = @Valid
    }
  }

  event login_failed(user_id: Id)
    requires exists u: User | u.id == user_id and u.status == @Active {
    choose u: User where u.id == user_id {
      u.record_failure()
    }
  }

  event auto_lock(user_id: Id)
    requires exists u: User |
      u.id == user_id and
      u.status == @Active and
      u.failed_attempts >= 5 {
    choose u: User where u.id == user_id {
      u.lock()
    }
    // Revoke all active sessions for locked user
    for s: Session {
      s.revoke()
    }
  }

  event logout(session_id: Id)
    requires exists s: Session | s.id == session_id and s.status == @Valid {
    choose s: Session where s.id == session_id {
      s.expire()
    }
  }

  event suspend_user(user_id: Id)
    requires exists u: User | u.id == user_id and u.status == @Active {
    choose u: User where u.id == user_id {
      u.suspend()
    }
    for s: Session {
      s.revoke()
    }
  }

  next {
    when exists u: User | u.failed_attempts >= 5 and u.status == @Active => Auth::auto_lock
    else => idle
  }
}

// Predicates
pred user_active(u: User) = u.status == @Active
pred session_valid(s: Session) = s.status == @Valid

// Properties
prop no_locked_sessions for Auth =
  always all s: Session | all u: User |
    u.status == @Locked and s.user_id == u.id implies s.status != @Valid

prop deleted_is_final for Auth =
  always all u: User | u.status == @Deleted implies always u.status == @Deleted

// Bounded checks
verify "auth safety" for Auth[0..10] {
  assert no_locked_sessions
  assert deleted_is_final
  assert always all u: User | u.failed_attempts >= 0
}

// Unbounded proof
proof "lockout correctness" for Auth
  invariant all u: User | u.failed_attempts >= 0
  invariant all u: User | u.status == @Locked implies u.failed_attempts >= 5 {
  show always all u: User |
    u.failed_attempts >= 5 and u.status == @Active implies
      eventually u.status == @Locked
}

// Scenario
scene "lockout after 5 failures" for Auth {
  given {
    let u = one User where u.status == @Active and u.failed_attempts == 0
  }
  when {
    action f1 = Auth::login_failed(u.id){one}
    action f2 = Auth::login_failed(u.id){one}
    action f3 = Auth::login_failed(u.id){one}
    action f4 = Auth::login_failed(u.id){one}
    action f5 = Auth::login_failed(u.id){one}
    action lock = Auth::auto_lock(u.id){one}
    assume f1 -> f2 -> f3 -> f4 -> f5 -> lock
  }
  then {
    assert u.status == @Locked
  }
}
