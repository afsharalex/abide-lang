module Imperative

// Imperative fn body examples (DDR-019)
// Demonstrates: var, while, if/else, assert, assume,
// invariant, decreases, blocks, nested control flow

// --- var declarations ---

fn sum_to(n: Int): Int
  requires n >= 0
  ensures result >= 0
{
  var total = 0
  var i = 0
  while i <= n
    invariant total >= 0
    invariant i >= 0
    decreases n - i
  {
    total = total + i
    i = i + 1
  }
  total
}

// --- if/else as expression ---

fn abs(x: Int): Int
  ensures result >= 0
{
  if x < 0 {
    0 - x
  } else {
    x
  }
}

fn max(a: Int, b: Int): Int
  ensures result >= a
  ensures result >= b
{
  if a >= b { a } else { b }
}

fn sign(x: Int): Int {
  if x > 0 {
    1
  } else {
    if x < 0 {
      0 - 1
    } else {
      0
    }
  }
}

// --- while with contracts ---

fn gcd_imperative(a: Int, b: Int): Int
  requires a > 0
  requires b >= 0
  ensures result > 0
{
  var x = a
  var y = b
  while y != 0
    invariant x > 0
    invariant y >= 0
    decreases y
  {
    var temp = y
    y = x % y
    x = temp
  }
  x
}

// --- assert and assume ---

fn checked_divide(a: Int, b: Int): Int
  requires b != 0
{
  assert b != 0
  a / b
}

fn with_assertion(x: Int): Int
  requires x > 0
{
  assert x > 0
  x + 1
}

// --- typed var declarations ---

fn fibonacci(n: Int): Int
  requires n >= 0
{
  var a: Int = 0
  var b: Int = 1
  var i: Int = 0
  while i < n
    decreases n - i
  {
    var temp: Int = b
    b = a + b
    a = temp
    i = i + 1
  }
  a
}

// --- simple block ---

fn compute(x: Int): Int {
  var doubled = x + x
  var incremented = doubled + 1
  incremented
}

// --- no contracts (pure = form still works) ---

fn double(x: Int): Int = x + x

fn is_positive(n: Int): Bool = n > 0
