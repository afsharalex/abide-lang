// Full Commerce example: entities with actions, system events,
// cross-system calls, choose + for, verify, proof, scene, import/use

import "billing.abide" as Billing
use Billing::{PaymentIntent as PI, open_intent, capture_payment}
use Billing::PaymentStatus as PS

type OrderStatus = Pending | AwaitingPayment | Paid | Shipped | Cancelled
type PaymentStatus = Opened | Captured | Failed
type Price = Int

type Address { street: String, city: String }

entity Order {
  field id: Id
  field total: Price
  field status: OrderStatus = @Pending

  action submit()
    requires status == @Pending
    requires total > 0 {
    status' = @AwaitingPayment
  }

  action mark_paid()
    requires status == @AwaitingPayment {
    status' = @Paid
  }

  action ship()
    requires status == @Paid {
    status' = @Shipped
  }

  action cancel()
    requires status == @Pending {
    status' = @Cancelled
  }
}

entity PaymentIntent {
  field order_id: Id
  field amount: Price
  field status: PaymentStatus = @Opened

  action capture()
    requires status == @Opened
    requires amount > 0 {
    status' = @Captured
  }

  action fail()
    requires status == @Opened {
    status' = @Failed
  }
}

system Commerce {
  uses Order

  event pay(order_id: Id)
    requires exists o: Order | o.id == order_id and o.status == @Pending {
    choose o: Order where o.id == order_id {
      o.submit()
    }
    Billing::open_intent(order_id: order_id)
  }

  event confirm_payment(order_id: Id)
    requires exists o: Order | o.id == order_id and o.status == @AwaitingPayment {
    choose o: Order where o.id == order_id {
      o.mark_paid()
    }
  }

  event ship_order(order_id: Id)
    requires exists o: Order | o.id == order_id and o.status == @Paid {
    choose o: Order where o.id == order_id {
      o.ship()
    }
  }

  event cancel_all_pending() {
    for o: Order {
      o.cancel()
    }
  }

  next {
    when exists o: Order | o.status == @AwaitingPayment => Commerce::confirm_payment
    when exists o: Order | o.status == @Paid => Commerce::ship_order
    else => idle
  }
}

system Billing {
  uses PaymentIntent

  event open_intent(order_id: Id) {
    create PaymentIntent {
      order_id = order_id
      amount = 0
      status = @Opened
    }
  }

  event capture_payment(order_id: Id)
    requires exists p: PaymentIntent | p.order_id == order_id and p.status == @Opened
    ensures exists p: PaymentIntent | p.order_id == order_id and p.status == @Captured {
    choose p: PaymentIntent where p.order_id == order_id {
      p.capture()
    }
    Commerce::confirm_payment(order_id: order_id)
  }

  next {
    else => idle
  }
}

pred non_negative_order_total(o: Order) = o.total >= 0

prop commerce_safe for Commerce = always all o: Order | non_negative_order_total(o)

// Bounded model checking — automated, scope-bounded
verify "commerce smoke" for Commerce[0..500] {
  assert commerce_safe
  assert eventually exists o: Order | o.status == @Paid
}

verify "billing safety" for Billing[0..500] {
  assert always all p: PaymentIntent | p.status == @Captured implies p.amount > 0
}

// Unbounded proof — human-guided, emits obligations to Agda
proof "order total non-negative" for Commerce
  invariant all o: Order | o.total >= 0 {
  show always all o: Order | non_negative_order_total(o)
}

lemma order_total_preserved {
  non_negative_order_total(o) implies non_negative_order_total(o)
}

scene "happy path" for Commerce {
  given {
    let o = one Order where o.total == 100
  }
  when {
    action pay_act = Commerce::pay(o.id){one}
    action cap = Billing::capture_payment(o.id){one}
    assume pay_act -> cap
  }
  then {
    assert o.status == @Paid
  }
}
