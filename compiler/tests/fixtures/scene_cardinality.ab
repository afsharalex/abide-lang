module SceneCardinality

// Phase 12: Scene event cardinality + ^| exclusive choice

enum Status = Pending | Confirmed | Shipped | Cancelled

entity Order {
  id: Id
  status: Status = @Pending
  action confirm() requires status == @Pending { status' = @Confirmed }
  action ship() requires status == @Confirmed { status' = @Shipped }
  action cancel() requires status == @Pending { status' = @Cancelled }
}

system Commerce {
  use Order
  event create_order() { create Order {} }
  event confirm_order(order_id: Id) {
    choose o: Order where o.id == order_id and o.status == @Pending { o.confirm() }
  }
  event ship_order(order_id: Id) {
    choose o: Order where o.id == order_id and o.status == @Confirmed { o.ship() }
  }
  event cancel_order(order_id: Id) {
    choose o: Order where o.id == order_id and o.status == @Pending { o.cancel() }
  }
}

// ── {lone}: event fires 0 or 1 times ───────────────────────────────

// Optional cancel — may or may not fire. Should PASS (solver skips cancel).
scene lone_fires_once for Commerce {
  given {
    let o = one Order where o.status == @Pending
  }
  when {
    action conf = Commerce::confirm_order(o.id){one}
    action can = Commerce::cancel_order(o.id){lone}
    assume conf -> can
  }
  then {
    assert o.status == @Confirmed or o.status == @Cancelled
  }
}

// Optional cancel doesn't fire — order stays confirmed. Should PASS.
scene lone_does_not_fire for Commerce {
  given {
    let o = one Order where o.status == @Pending
  }
  when {
    action conf = Commerce::confirm_order(o.id){one}
    action can = Commerce::cancel_order(o.id){lone}
  }
  then {
    assert o.status == @Confirmed
  }
}

// ── {no}: event never fires ─────────────────────────────────────────

// Cancel never fires — order gets confirmed and shipped. Should PASS.
scene no_cancel for Commerce {
  given {
    let o = one Order where o.status == @Pending
  }
  when {
    action conf = Commerce::confirm_order(o.id){one}
    action ship_act = Commerce::ship_order(o.id){one}
    action can = Commerce::cancel_order(o.id){no}
    assume conf -> ship_act
  }
  then {
    assert o.status == @Shipped
  }
}

// ── {N}: event fires exactly N times ────────────────────────────────

// Create exactly 2 orders. Should PASS.
scene exact_two_creates for Commerce {
  given {
    let o = one Order where o.status == @Pending
  }
  when {
    action mk = Commerce::create_order(){2}
  }
  then {
    assert exists o2: Order | o2.status == @Pending
  }
}

// ── {some}: event fires 1 or more times ─────────────────────────────

// Create at least one order. Should PASS.
scene some_creates for Commerce {
  given {
    let o = one Order where o.status == @Pending
  }
  when {
    action mk = Commerce::create_order(){some}
  }
  then {
    assert exists o2: Order | o2.status == @Pending
  }
}

// ── ^| exclusive choice ─────────────────────────────────────────────

enum LogKind = Info | Warning
entity AuditLog {
  kind: LogKind = @Info
  action mark_warning() requires kind == @Info { kind' = @Warning }
}

system Audited {
  use Order
  use AuditLog
  event confirm_order(order_id: Id) {
    choose o: Order where o.id == order_id and o.status == @Pending { o.confirm() }
  }
  event cancel_order(order_id: Id) {
    choose o: Order where o.id == order_id and o.status == @Pending { o.cancel() }
  }
}

// Exactly one of confirm or cancel fires. Should PASS.
scene xor_confirm_or_cancel for Audited {
  given {
    let o = one Order where o.status == @Pending
  }
  when {
    action conf = Audited::confirm_order(o.id){one}
    action can = Audited::cancel_order(o.id){one}
    assume conf ^| can
  }
  then {
    assert o.status == @Confirmed or o.status == @Cancelled
  }
}

// {lone} inside same-step &: optional event on different entity can skip.
// confirm (Order) always fires, warn (AuditLog) is optional. Should PASS
// even if warn skips — AuditLog stays @Info.
system AuditActions {
  use Order
  use AuditLog
  event confirm_order(order_id: Id) {
    choose o: Order where o.id == order_id and o.status == @Pending { o.confirm() }
  }
  event warn_log() {
    choose l: AuditLog where l.kind == @Info { l.mark_warning() }
  }
}

scene lone_in_same_step for AuditActions {
  given {
    let o = one Order where o.status == @Pending
    let l = one AuditLog where l.kind == @Info
  }
  when {
    action conf = AuditActions::confirm_order(o.id){one}
    action warn = AuditActions::warn_log(){lone}
    assume (conf & warn)
  }
  then {
    // confirm always fires; warn is optional.
    // Order becomes Confirmed. AuditLog may or may not change.
    assert o.status == @Confirmed
  }
}

// ^| with exact {1} cardinality — should behave like {one}. Should PASS.
scene xor_exact_one for Audited {
  given {
    let o = one Order where o.status == @Pending
  }
  when {
    action conf = Audited::confirm_order(o.id){1}
    action can = Audited::cancel_order(o.id){1}
    assume conf ^| can
  }
  then {
    assert o.status == @Confirmed or o.status == @Cancelled
  }
}

// ^| requires both to be IMPOSSIBLE simultaneously — should FAIL
scene xor_both_required for Audited {
  given {
    let o = one Order where o.status == @Pending
  }
  when {
    action conf = Audited::confirm_order(o.id){one}
    action can = Audited::cancel_order(o.id){one}
    assume conf ^| can
  }
  then {
    // Can't require both — only one fires
    assert o.status == @Confirmed and o.status == @Cancelled
  }
}
