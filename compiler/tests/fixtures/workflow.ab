module Workflow

// Document approval workflow example
// Demonstrates: multi-step state machines, role-based guards,
// exclusive choice, temporal liveness, proof obligations

enum DocStatus = Draft | Submitted | UnderReview | Approved | Rejected | Published | Archived
enum ReviewResult = Pass | Fail | NeedsRevision
enum Priority = Low | Medium | High | Critical

entity Document {
  id: Id
  author_id: Id
  reviewer_id: Id
  status: DocStatus = @Draft
  priority: Priority = @Medium
  revision_count: Int

  action submit()
    requires status == @Draft {
    status' = @Submitted
  }

  action assign_reviewer(reviewer: Id)
    requires status == @Submitted {
    status' = @UnderReview
    reviewer_id' = reviewer
  }

  action approve()
    requires status == @UnderReview {
    status' = @Approved
  }

  action reject()
    requires status == @UnderReview {
    status' = @Rejected
  }

  action request_revision()
    requires status == @UnderReview {
    status' = @Draft
    revision_count' = revision_count + 1
  }

  action publish()
    requires status == @Approved {
    status' = @Published
  }

  action archive()
    requires status == @Published {
    status' = @Archived
  }

  action reopen()
    requires status == @Rejected {
    status' = @Draft
    revision_count' = revision_count + 1
  }
}

entity AuditEntry {
  id: Id
  doc_id: Id
  action_name: String
  actor_id: Id
}

system DocumentMgmt {
  use Document
  use AuditEntry

  event submit_document(doc_id: Id, author_id: Id)
    requires exists d: Document | d.id == doc_id and d.author_id == author_id and d.status == @Draft {
    choose d: Document where d.id == doc_id {
      d.submit()
    }
    create AuditEntry {
      doc_id = doc_id
      action_name = "submit"
      actor_id = author_id
    }
  }

  event assign_review(doc_id: Id, reviewer_id: Id)
    requires exists d: Document | d.id == doc_id and d.status == @Submitted
    // Reviewer cannot be the author
    requires exists d: Document | d.id == doc_id and d.author_id != reviewer_id {
    choose d: Document where d.id == doc_id {
      d.assign_reviewer(reviewer_id)
    }
    create AuditEntry {
      doc_id = doc_id
      action_name = "assign_review"
      actor_id = reviewer_id
    }
  }

  // Review produces exactly one of: approve, reject, or request_revision
  event review_approve(doc_id: Id, reviewer_id: Id)
    requires exists d: Document |
      d.id == doc_id and
      d.status == @UnderReview and
      d.reviewer_id == reviewer_id {
    choose d: Document where d.id == doc_id {
      d.approve()
    }
    create AuditEntry {
      doc_id = doc_id
      action_name = "approve"
      actor_id = reviewer_id
    }
  }

  event review_reject(doc_id: Id, reviewer_id: Id)
    requires exists d: Document |
      d.id == doc_id and
      d.status == @UnderReview and
      d.reviewer_id == reviewer_id {
    choose d: Document where d.id == doc_id {
      d.reject()
    }
    create AuditEntry {
      doc_id = doc_id
      action_name = "reject"
      actor_id = reviewer_id
    }
  }

  event review_revise(doc_id: Id, reviewer_id: Id)
    requires exists d: Document |
      d.id == doc_id and
      d.status == @UnderReview and
      d.reviewer_id == reviewer_id {
    choose d: Document where d.id == doc_id {
      d.request_revision()
    }
    create AuditEntry {
      doc_id = doc_id
      action_name = "request_revision"
      actor_id = reviewer_id
    }
  }

  event publish_document(doc_id: Id)
    requires exists d: Document | d.id == doc_id and d.status == @Approved {
    choose d: Document where d.id == doc_id {
      d.publish()
    }
  }

  event archive_document(doc_id: Id)
    requires exists d: Document | d.id == doc_id and d.status == @Published {
    choose d: Document where d.id == doc_id {
      d.archive()
    }
  }

  event reopen_document(doc_id: Id, author_id: Id)
    requires exists d: Document |
      d.id == doc_id and
      d.status == @Rejected and
      d.author_id == author_id {
    choose d: Document where d.id == doc_id {
      d.reopen()
    }
  }

  next {
    when exists d: Document | d.status == @Submitted => DocumentMgmt::assign_review
    when exists d: Document | d.status == @Approved => DocumentMgmt::publish_document
    else => idle
  }
}

// Predicates
pred is_terminal(d: Document) =
  d.status == @Published or d.status == @Archived

pred revision_bounded(d: Document) =
  d.revision_count >= 0

// Properties
prop terminal_is_final for DocumentMgmt =
  always all d: Document |
    d.status == @Archived implies always d.status == @Archived

prop revisions_non_negative for DocumentMgmt =
  always all d: Document | revision_bounded(d)

prop review_exclusivity for DocumentMgmt =
  always all d: Document |
    d.status == @UnderReview implies
      eventually (d.status == @Approved ^| d.status == @Rejected ^| d.status == @Draft)

prop eventual_resolution for DocumentMgmt =
  always all d: Document |
    d.status == @Submitted implies eventually (is_terminal(d) or d.status == @Draft)

// Bounded checks
verify workflow_safety for DocumentMgmt[0..10] {
  assert terminal_is_final
  assert revisions_non_negative
  assert review_exclusivity
}

verify workflow_liveness for DocumentMgmt[0..5] {
  assert eventual_resolution
}

// Proofs
theorem revision_count_monotonic for DocumentMgmt
  invariant all d: Document | d.revision_count >= 0 {
  show always all d: Document |
    d.revision_count >= 0
}

// Scenarios
scene happy_path_submit_to_publish for DocumentMgmt {
  given {
    let d = one Document where d.status == @Draft and d.revision_count == 0
  }
  when {
    action sub = DocumentMgmt::submit_document(d.id, d.author_id){one}
    action rev = DocumentMgmt::assign_review(d.id, d.reviewer_id){one}
    action app = DocumentMgmt::review_approve(d.id, d.reviewer_id){one}
    action publ = DocumentMgmt::publish_document(d.id){one}
    assume sub -> rev -> app -> publ
  }
  then {
    assert d.status == @Published
    assert d.revision_count == 0
  }
}

scene revision_cycle for DocumentMgmt {
  given {
    let d = one Document where d.status == @Draft and d.revision_count == 0
  }
  when {
    action sub1 = DocumentMgmt::submit_document(d.id, d.author_id){one}
    action rev1 = DocumentMgmt::assign_review(d.id, d.reviewer_id){one}
    action revise = DocumentMgmt::review_revise(d.id, d.reviewer_id){one}
    action sub2 = DocumentMgmt::submit_document(d.id, d.author_id){one}
    action rev2 = DocumentMgmt::assign_review(d.id, d.reviewer_id){one}
    action app = DocumentMgmt::review_approve(d.id, d.reviewer_id){one}
    assume sub1 -> rev1 -> revise -> sub2 -> rev2 -> app
  }
  then {
    assert d.status == @Approved
    assert d.revision_count == 1
  }
}

scene rejection_and_reopen for DocumentMgmt {
  given {
    let d = one Document where d.status == @Draft
  }
  when {
    action sub = DocumentMgmt::submit_document(d.id, d.author_id){one}
    action rev = DocumentMgmt::assign_review(d.id, d.reviewer_id){one}
    action rej = DocumentMgmt::review_reject(d.id, d.reviewer_id){one}
    action reopen = DocumentMgmt::reopen_document(d.id, d.author_id){one}
    assume sub -> rev -> rej -> reopen
  }
  then {
    assert d.status == @Draft
  }
}
