module MatchExhaustive

// Match exhaustiveness checking tests

enum Color = Red | Green | Blue

enum Shape = Circle { radius: int } | Rectangle { width: int, height: int }

// ── Exhaustive matches (should pass) ────────────────────────────────

// All constructors covered
fn color_name(c: Color): string
  = match c {
    Red => "red"
    Green => "green"
    Blue => "blue"
  }

// Wildcard covers remainder
fn is_red(c: Color): bool
  = match c {
    Red => true
    _ => false
  }

// Or-pattern covers multiple constructors
fn is_warm(c: Color): bool
  = match c {
    Red | Green => true
    Blue => false
  }

// Variable (non-constructor name) covers remainder
fn color_code(c: Color): int
  = match c {
    Red => 1
    other => 0
  }

// Record patterns — all constructors covered
fn area(s: Shape): int
  = match s {
    Circle { radius: r } => r * r
    Rectangle { width: w, height: h } => w * h
  }

// Guard with wildcard fallback — exhaustive
fn classify(c: Color): string
  = match c {
    Red if true => "definitely red"
    _ => "something else"
  }

// Type alias chain — exhaustive
type Hue = Color
type Paint = Hue

fn paint_name(p: Paint): string
  = match p {
    Red => "red paint"
    Green => "green paint"
    Blue => "blue paint"
  }
