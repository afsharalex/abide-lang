module Inventory

// Inventory management example
// Demonstrates: multiple entity types interacting, quantity tracking,
// cross-system coordination, exclusive choice, concurrent operations

enum ProductStatus = Available | Discontinued | OutOfStock
enum ReservationStatus = Held | Confirmed | Released | Expired
enum FulfillmentStatus = Pending | Picking | Packed | Shipped | Delivered

entity Product {
  id: identity
  name: string
  quantity: int
  status: ProductStatus = @Available

  action restock(amount: int)
    requires status != @Discontinued
    requires amount > 0 {
    quantity' = quantity + amount
    status' = @Available
  }

  action reserve(amount: int)
    requires status == @Available
    requires quantity >= amount
    requires amount > 0 {
    quantity' = quantity - amount
  }

  action release(amount: int)
    requires amount > 0 {
    quantity' = quantity + amount
  }

  action discontinue()
    requires status == @Available {
    status' = @Discontinued
  }

  action mark_out_of_stock()
    requires quantity == 0
    requires status == @Available {
    status' = @OutOfStock
  }
}

entity Reservation {
  id: identity
  product_id: identity
  quantity: int
  status: ReservationStatus = @Held

  action confirm()
    requires status == @Held {
    status' = @Confirmed
  }

  action release()
    requires status == @Held {
    status' = @Released
  }

  action expire()
    requires status == @Held {
    status' = @Expired
  }
}

entity Fulfillment {
  id: identity
  reservation_id: identity
  status: FulfillmentStatus = @Pending

  action start_picking()
    requires status == @Pending {
    status' = @Picking
  }

  action pack()
    requires status == @Picking {
    status' = @Packed
  }

  action ship()
    requires status == @Packed {
    status' = @Shipped
  }

  action deliver()
    requires status == @Shipped {
    status' = @Delivered
  }
}

system Warehouse(products: Store<Product>, reservations: Store<Reservation>) {

  command reserve_product(product_id: identity, qty: int)

  step reserve_product(product_id: identity, qty: int)
    requires exists p: Product |
      p.id == product_id and
      p.status == @Available and
      p.quantity >= qty
    requires qty > 0 {
    choose p: Product where p.id == product_id {
      p.reserve(qty)
    }
    create Reservation {
      product_id = product_id
      quantity = qty
      status = @Held
    }
  }

  command release_reservation(reservation_id: identity)

  step release_reservation(reservation_id: identity)
    requires exists r: Reservation |
      r.id == reservation_id and r.status == @Held {
    choose r: Reservation where r.id == reservation_id {
      r.release()
    }
    // Return quantity to product
    choose p: Product where p.id == r.product_id {
      p.release(r.quantity)
    }
  }

  command confirm_reservation(reservation_id: identity)

  step confirm_reservation(reservation_id: identity)
    requires exists r: Reservation |
      r.id == reservation_id and r.status == @Held {
    choose r: Reservation where r.id == reservation_id {
      r.confirm()
    }
    Shipping::begin_fulfillment(reservation_id: reservation_id)
  }

  command restock_product(product_id: identity, amount: int)

  step restock_product(product_id: identity, amount: int)
    requires exists p: Product | p.id == product_id
    requires amount > 0 {
    choose p: Product where p.id == product_id {
      p.restock(amount)
    }
  }
}

system Shipping(fulfillments: Store<Fulfillment>) {

  command begin_fulfillment(reservation_id: identity)

  step begin_fulfillment(reservation_id: identity) {
    create Fulfillment {
      reservation_id = reservation_id
      status = @Pending
    }
  }

  command pick(fulfillment_id: identity)

  step pick(fulfillment_id: identity)
    requires exists f: Fulfillment |
      f.id == fulfillment_id and f.status == @Pending {
    choose f: Fulfillment where f.id == fulfillment_id {
      f.start_picking()
    }
  }

  // Sequential composition: pack then ship in one atomic step.
  // Uses intermediate variable chaining — ship's guard sees pack's result.
  command pack_and_ship(fulfillment_id: identity)

  step pack_and_ship(fulfillment_id: identity)
    requires exists f: Fulfillment |
      f.id == fulfillment_id and f.status == @Picking {
    choose f: Fulfillment where f.id == fulfillment_id {
      f.pack()
      f.ship()
    }
  }

  command mark_delivered(fulfillment_id: identity)

  step mark_delivered(fulfillment_id: identity)
    requires exists f: Fulfillment |
      f.id == fulfillment_id and f.status == @Shipped {
    choose f: Fulfillment where f.id == fulfillment_id {
      f.deliver()
    }
  }
}

// Predicates
pred quantity_non_negative(p: Product) = p.quantity >= 0
pred reservation_consistent(r: Reservation) =
  r.status == @Released implies r.quantity >= 0

// Properties
prop inventory_safe for Warehouse =
  always all p: Product | quantity_non_negative(p)

prop fulfillment_progress for Shipping =
  always all f: Fulfillment |
    f.status == @Pending implies eventually f.status == @Shipped

// Bounded checks
verify inventory_safety {
  assume {
    store products: Product[0..8]
    store reservations: Reservation[0..8]
    let warehouse = Warehouse { products: products, reservations: reservations }
  }
  assert inventory_safe
}

verify end_to_end {
  assume {
    store products: Product[0..8]
    store reservations: Reservation[0..8]
    let warehouse = Warehouse { products: products, reservations: reservations }
    store fulfillments: Fulfillment[0..8]
    let shipping = Shipping { fulfillments: fulfillments }
  }
  assert always all p: Product | p.quantity >= 0
  assert always all f: Fulfillment |
    f.status == @Delivered implies always f.status == @Delivered
}

// Scenarios
scene reserve_and_confirm {
  given {
    store products: Product[0..2]
    store reservations: Reservation[0..2]
    let warehouse = Warehouse { products: products, reservations: reservations }
    let p = one Product in products where p.quantity == 50 and p.status == @Available
    let r = one Reservation in reservations
  }
  when {
    let warehouse_reserve_product = warehouse.reserve_product(p.id, 10)
    let warehouse_confirm_reservation = warehouse.confirm_reservation(r.id)
    assume warehouse_reserve_product -> warehouse_confirm_reservation
  }
  then {
    assert p.quantity == 40
  }
}

scene reservation_release_restores_quantity {
  given {
    store products: Product[0..2]
    store reservations: Reservation[0..2]
    let warehouse = Warehouse { products: products, reservations: reservations }
    let p = one Product in products where p.quantity == 100
    let r = one Reservation in reservations
  }
  when {
    let warehouse_reserve_product = warehouse.reserve_product(p.id, 25)
    let warehouse_release_reservation = warehouse.release_reservation(r.id)
    assume warehouse_reserve_product -> warehouse_release_reservation
  }
  then {
    assert p.quantity == 100
  }
}
