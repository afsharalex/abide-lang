module OneLone

// Quantifier cardinality tests
// Tests that `one` means "exactly one" and `lone` means "at most one".

enum Color = Red | Green | Blue

// --- one: exactly one (should PROVE) ---

// Exactly one Color equals Red — true (Red is unique)
fn one_enum_exact(): bool
  ensures one c: Color | c == @Color::Red
{
  true
}

// --- one: exactly one fails when none match (should FAIL) ---

// No Color satisfies this impossible predicate
fn one_enum_none(): bool
  ensures one c: Color | c == @Color::Red and c == @Color::Green
{
  true
}

// --- one: exactly one fails when multiple match (should FAIL) ---

// Red and Green both satisfy the disjunction — not exactly one
fn one_enum_multiple(): bool
  ensures one c: Color | c == @Color::Red or c == @Color::Green
{
  true
}

// --- lone: at most one (should PROVE when exactly one) ---

fn lone_enum_one(): bool
  ensures lone c: Color | c == @Color::Red
{
  true
}

// --- lone: at most one (should PROVE when none) ---

fn lone_enum_none(): bool
  ensures lone c: Color | c == @Color::Red and c == @Color::Green
{
  true
}

// --- lone: at most one (should FAIL when multiple) ---

fn lone_enum_multiple(): bool
  ensures lone c: Color | c == @Color::Red or c == @Color::Green
{
  true
}

// --- one with int domain ---

// Exactly one int in [1..3] equals 2
fn one_int_exact(x: int): bool
  ensures one y: int | y >= 1 and y <= 3 and y == 2
{
  true
}

// --- lone with int domain ---

// At most one int equals the given value (trivially true — equality is unique)
fn lone_int_unique(x: int): bool
  ensures lone y: int | y == x
{
  true
}

// --- one in requires ---

// Function with one in requires and ensures — the requires constraint is
// available when proving the ensures postcondition
fn one_in_requires(x: int): int
  requires one c: Color | c == @Color::Red
  ensures result == x
{
  x
}

// --- ADT-domain (field-bearing enum) quantifiers ---

enum Shape = Circle { r: int } | Square { s: int }

// lone with match destructuring on ADT — exactly one Circle{r:1} satisfies
fn lone_adt_match(): bool
  ensures lone sh: Shape | match sh {
    Circle { r: r } => r == 1
    Square { s: s } => false
  }
{
  true
}

// lone with ADT — multiple Shapes satisfy (both Circle{r>0} and Square{s>0})
fn lone_adt_multiple(): bool
  ensures lone sh: Shape | match sh {
    Circle { r: r } => r > 0
    Square { s: s } => s > 0
  }
{
  true
}

// one with ADT equality
fn one_adt_eq(): bool
  ensures one sh: Shape | sh == @Shape::Circle { r: 42 }
{
  true
}

// exists with ADT — pre-existing quantifier, should also work
fn exists_adt(): bool
  ensures exists sh: Shape | sh == @Shape::Square { s: 7 }
{
  true
}
